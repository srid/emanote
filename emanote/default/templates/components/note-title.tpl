<!-- Note title attached as a top strip on the container card (see
     layouts/default.tpl). The md:rounded-t-lg matches the container's
     md:rounded-lg so the strip's top corners flow into the card's
     curve; the bottom is square so it sits flush against the inner
     row below (sidebar / body / right-panel). -->
<header class="px-8 py-5 md:rounded-t-lg bg-primary-600 dark:bg-primary-800 text-white text-center">
  <h1 class="text-3xl md:text-4xl font-bold">
    <ema:note:title />
  </h1>
</header>
